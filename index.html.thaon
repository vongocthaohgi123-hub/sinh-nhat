<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trò Chơi Siêu ỨC CHẾ</title>
    <style>
        /* Toàn bộ game sử dụng giao diện nền đen chữ trắng tối giản */
        body {
            background-color: #000000;
            color: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            user-select: none;
        }

        .container {
            width: 100%;
            max-width: 450px;
            padding: 20px;
            box-sizing: border-box;
            text-align: center;
        }

        h2, p {
            line-height: 1.5;
            font-size: 18px;
        }

        /* Nút bấm của game */
        .btn {
            background: #ffffff;
            color: #000000;
            border: none;
            padding: 12px 25px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 25px;
            cursor: pointer;
            width: 100%;
            margin-bottom: 15px;
            box-sizing: border-box;
            transition: background 0.2s;
        }

        .btn:hover {
            background: #cccccc;
        }

        .btn-flag {
            font-size: 50px;
            background: none;
            border: none;
            cursor: pointer;
            margin: 0 20px;
            transition: transform 0.2s;
        }

        .btn-flag:hover {
            transform: scale(1.2);
        }

        .input-field {
            width: 100%;
            padding: 12px;
            background: #111;
            border: 1px solid #333;
            border-radius: 8px;
            color: #fff;
            font-size: 15px;
            box-sizing: border-box;
            margin-bottom: 15px;
            text-align: center;
        }

        /* KHU VỰC ĐỒ HỌA PIXEL MÈO DI CHUYỂN */
        .game-map {
            width: 100%;
            height: 150px;
            background: #111;
            border: 2px dashed #333;
            border-radius: 10px;
            position: relative;
            margin: 20px 0;
            overflow: hidden;
        }

        .pixel-cat {
            font-size: 30px;
            position: absolute;
            bottom: 20px;
            left: 50px;
            transition: left 0.1s ease;
        }

        .objective-point {
            font-size: 30px;
            position: absolute;
            bottom: 20px;
            right: 50px;
        }

        /* Bàn phím điều khiển ảo */
        .controls {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 15px;
        }

        .btn-control {
            background: #222;
            color: #fff;
            border: 1px solid #444;
            width: 60px;
            height: 50px;
            font-size: 20px;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
        }

        .btn-control:active {
            background: #444;
        }

        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>

    <div class="container">

        <div id="screen-hello">
            <h1 style="font-size: 32px; font-weight: 300; margin-bottom: 40px;">Xin chào</h1>
            <button class="btn" style="width: auto; border-radius: 50%; width: 50px; height: 50px; padding: 0;" onclick="nextScreen('screen-hello', 'screen-warning')">></button>
        </div>

        <div id="screen-warning" class="hidden">
            <p>Bạn sẵn sàng để chơi? Tôi cảnh báo trước là trò chơi này sẽ gây ức chế cho bạn, hông có bất cứ khiếu nại nào nhé?</p>
            <button class="btn" onclick="nextScreen('screen-warning', 'screen-lgbt')">toi dong tinh</button>
            <button class="btn" onclick="exitGame()" style="background: #222; color: #888; border: 1px solid #333;">toi khong dong tinh</button>
        </div>

        <div id="screen-crash" class="hidden">
            <h1 style="color: #ff3333; font-size: 40px;">⚠️ LỖI HỆ THỐNG</h1>
            <p>Ứng dụng đã bị đóng cưỡng chế do bạn từ chối điều khoản hoặc bị troll!</p>
            <p style="color: #555; font-size: 14px;">(Vui lòng tải lại trang nếu muốn hồi sinh)</p>
        </div>

        <div id="screen-lgbt" class="hidden">
            <h2>Bạn thuộc phe nào?</h2>
            <div style="margin: 30px 0;">
                <button class="btn-flag" onclick="chooseFlag('gay')">🏳️‍🌈</button>
                <button class="btn-flag" onclick="chooseFlag('lgbt')">🏳️‍⚧️</button>
            </div>
            <h3 id="flag-result" style="color: #ffeb3b; min-height: 30px;"></h3>
            <button id="btn-go-game" class="btn hidden" onclick="nextScreen('screen-lgbt', 'screen-intro-cat')">Bắt đầu vào game</button>
        </div>

        <div id="screen-intro-cat" class="hidden">
            <div style="font-size: 60px; margin-bottom: 10px;">🐱</div>
            <p>"Bạn là một chú mèo hộ mệnh, bạn thường sẽ giúp đỡ người khó khăn"</p>
            <button class="btn" onclick="startCatAdventure()">Tiếp tục</button>
        </div>

        <div id="screen-map-adventure" class="hidden">
            <h2 id="map-instruction">Hãy di chuyển lại gần người gặp khó khăn và ấn nút 0</h2>
            <div class="game-map">
                <div id="cat-character" class="pixel-cat">🐱</div>
                <div id="target-emoji" class="objective-point">🧍</div>
            </div>
            <div class="controls">
                <button class="btn-control" onclick="moveCat(-20)">&lt;</button>
                <button class="btn-control" onclick="interactCat()">0</button>
                <button class="btn-control" onclick="moveCat(20)">&gt;</button>
            </div>
        </div>

        <div id="quest-uncle" class="hidden">
            <div style="background: #111; padding: 15px; border-radius: 8px; text-align: left; margin-bottom: 20px;">
                <p><span style="color: #ff9800;">🐱 Mèo:</span> "Xin chào"</p>
                <p><span style="color: #2196f3;">👨 Ông chú:</span> "Chào mèo con"</p>
                <p><span style="color: #ff9800;">🐱 Mèo:</span> "Tâm sự một chút?"</p>
                <p><span style="color: #2196f3;">👨 Ông chú:</span> "Tôi đang ăn cơm với cá, tôi thấy ăn một tô cơm không đủ no"</p>
            </div>
            <h2>Câu hỏi: Ông chú cần ăn bao nhiêu tô cơm mới no?</h2>
            <button class="btn" onclick="answerUncle(true)">Ăn 3 tô cơm</button>
            <button class="btn" onclick="answerUncle(false)">Ăn 2 tô cơm</button>
            <p id="uncle-feedback" style="color: #ff3333; font-weight: bold;"></p>
        </div>

        <div id="quest-colab" class="hidden">
            <div style="font-size: 45px; margin-bottom: 10px;">👬⛰️</div>
            <h2>Chú mèo gặp hai anh chàng colab với nhau ngoài đường để lên đỉnh. Chú mèo cần làm gì để giúp họ?</h2>
            <button class="btn" onclick="answerColab()">Giúp họ colab</button>
            <button class="btn" onclick="answerColab()">Giúp họ lên đỉnh</button>
            <p id="colab-feedback" style="color: #4caf50; font-weight: bold;"></p>
        </div>

        <div id="quest-basketball" class="hidden">
            <div style="font-size: 45px; margin-bottom: 10px;">🏀🤰</div>
            <h2>Một vận động viên bóng rổ bị béo phì. Làm sao để giúp anh ấy thắng trận bóng?</h2>
            <button class="btn" onclick="answerBasketball(true)">Nói rằng anh ấy có thai để đội bạn nhường</button>
            <button class="btn" onclick="answerBasketball(false)">Dùng thuốc kích thích (vi phạm)</button>
            <p id="basketball-feedback" style="color: #ff3333; font-weight: bold;"></p>
        </div>

        <div id="quest-math" class="hidden">
            <h2>Cho chóp tam giác đều ABC, tâm O, và đỉnh chóp là "YEUNHAU". Chứng minh?</h2>
            <input type="text" id="math-answer" class="input-field" placeholder="Nhập đáp án chứng minh của bạn...">
            <button class="btn" onclick="checkMathAnswer()">Nộp đáp án</button>
            <button class="btn" id="btn-hint" onclick="giveMathHint()" style="background: #222; color: #aaa; border: 1px solid #333;">Xem gợi ý (<span id="hint-count">3</span> lần)</button>
            <p id="math-feedback" style="line-height: 1.6; font-weight: bold;"></p>
        </div>

        <div id="quest-smart" class="hidden">
            <h2>"Người ta thường nói, người thông minh thường nói rất nhiều, bạn thấy đúng không?"</h2>
            <button class="btn" onclick="answerSmart(true)">Đúng</button>
            <button class="btn" onclick="answerSmart(false)">Sai</button>
            <h2 id="smart-feedback" style="color: #00e676; margin-top: 20px;"></h2>
            <button id="btn-go-end" class="btn hidden" onclick="nextScreen('quest-smart', 'screen-gameover')">Tiếp tục</button>
        </div>

        <div id="screen-gameover" class="hidden">
            <h1 style="font-size: 36px; color: #00e676;">Trò chơi kết thúc</h1>
            <h2>Bạn thấy thế nào?</h2>
            <button class="btn" onclick="answerFeel()">Rất vui 🥰</button>
            <button class="btn" onclick="answerFeel()">Ncc 🥰</button>
            
            <div id="troll-zone" class="hidden" style="margin-top: 30px;">
                <button class="btn" onclick="exitGame()" style="background: #ff3333; color: #fff;">Chơi lại nào</button>
            </div>
        </div>

    </div>

    <script>
        // Quản lý danh sách các khó khăn cần vượt qua bằng cơ chế Random mẫu
        let questList = ['uncle', 'colab', 'basketball'];
        let currentQuest = "";
        let catPosition = 50; // Vị trí xuất phát của mèo

        // Hàm chuyển màn hình cơ bản
        function nextScreen(hideId, showId) {
            document.getElementById(hideId).classList.add('hidden');
            document.getElementById(showId).classList.remove('hidden');
        }

        // Tính năng văng game / Crash game để troll người chơi
        function exitGame() {
            // Ẩn tất cả nội dung trên màn hình để đưa về màn hình lỗi đen xì văng game
            const screens = document.querySelectorAll('.container > div');
            screens.forEach(s => s.classList.add('hidden'));
            document.getElementById('screen-crash').classList.remove('hidden');
        }

        // Chọn phe LGBT
        function chooseFlag(type) {
            const txt = document.getElementById('flag-result');
            if (type === 'gay') {
                txt.innerText = "bạn gay 😛";
            } else {
                txt.innerText = "bạn Lgbt 😛";
            }
            document.getElementById('btn-go-game').classList.remove('hidden');
        }

        // Bắt đầu chuyến phiêu lưu ngẫu nhiên của mèo hộ mệnh
        function startCatAdventure() {
            document.getElementById('screen-intro-cat').classList.add('hidden');
            pickRandomQuest();
        }

        // Hàm chọn Ngẫu nhiên (Random) nhiệm vụ cho đến khi hết danh sách khó khăn
        function pickRandomQuest() {
            if (questList.length > 0) {
                // Lấy ngẫu nhiên một vị trí trong mảng
                let randomIndex = Math.floor(Math.random() * questList.length);
                currentQuest = questList[randomIndex];
                // Xóa nhiệm vụ đó ra khỏi danh sách để không trùng lặp lại
                questList.splice(randomIndex, 1);

                // Cập nhật icon trên bản đồ tương ứng với từng nhiệm vụ
                const target = document.getElementById('target-emoji');
                if (currentQuest === 'uncle') target.innerText = "👨";
                if (currentQuest === 'colab') target.innerText = "👬";
                if (currentQuest === 'basketball') target.innerText = "🏀";

                // Đặt lại vị trí mèo về ban đầu và hiện bản đồ di chuyển
                catPosition = 50;
                document.getElementById('cat-character').style.left = catPosition + 'px';
                document.getElementById('map-instruction').innerText = "Hãy di chuyển lại gần người gặp khó khăn và ấn nút 0";
                document.getElementById('screen-map-adventure').classList.remove('hidden');
            } else {
                // Khi đã hoàn thành hết tất cả 3 khó khăn random, tiến vào chuỗi câu hỏi hại não cuối cùng
                nextScreen('screen-map-adventure', 'quest-math');
            }
        }

        // Hệ thống điều khiển nút mũi tên tiến/lùi < > của con mèo pixel
        function moveCat(offset) {
            catPosition += offset;
            // Giới hạn không cho mèo chạy ra ngoài map
            if (catPosition < 10) catPosition = 10;
            if (catPosition > 350) catPosition = 350;
            document.getElementById('cat-character').style.left = catPosition + 'px';
        }

        // Hệ thống nhấn nút 0 để kích hoạt màn hình câu hỏi khó khăn
        function interactCat() {
            // Kiểm tra xem chú mèo đã di chuyển đến đủ sát vị trí của mục tiêu chưa (vị trí đích khoảng 310-350px)
            if (catPosition >= 270) {
                document.getElementById('screen-map-adventure').classList.add('hidden');
                
                if (currentQuest === 'uncle') {
                    document.getElementById('quest-uncle').classList.remove('hidden');
                } else if (currentQuest === 'colab') {
                    document.getElementById('quest-colab').classList.remove('hidden');
                } else if (currentQuest === 'basketball') {
                    document.getElementById('quest-basketball').classList.remove('hidden');
                }
            } else {
                document.getElementById('map-instruction').innerText = "Chưa đến nơi! Hãy bấm nút > để đi sát lại gần mục tiêu đã nè!";
            }
        }

        // Xử lý Đáp án Khó khăn 1: Ông chú ăn cơm cá
        function answerUncle(isCorrect) {
            const feedback = document.getElementById('uncle-feedback');
            if (isCorrect) {
                feedback.style.color = "#4caf50";
                feedback.innerText = "Chính xác! Ông chú đã no nê. Chuẩn bị qua thử thách tiếp theo...";
                setTimeout(() => {
                    document.getElementById('quest-uncle').classList.add('hidden');
                    feedback.innerText = "";
                    pickRandomQuest();
                }, 2000);
            } else {
                feedback.style.color = "#ff3333";
                feedback.innerText = "Sai rồi, ăn 2 tô vẫn đói meo à! Chọn lại đi bạn!";
            }
        }

        // Xử lý Đáp án Khó khăn 2: Hai anh chàng colab (Cả hai đều đúng)
        function answerColab() {
            const feedback = document.getElementById('colab-feedback');
            feedback.innerText = "Chuẩn luôn cả hai đáp án đều đúng =)) Đang chuyển cảnh...";
            setTimeout(() => {
                document.getElementById('quest-colab').classList.add('hidden');
                feedback.innerText = "";
                pickRandomQuest();
            }, 2000);
        }

        // Xử lý Đáp án Khó khăn 3: Vận động viên béo phì
        function answerBasketball(isCorrect) {
            const feedback = document.getElementById('basketball-feedback');
            if (isCorrect) {
                feedback.style.color = "#4caf50";
                feedback.innerText = "Đúng rồi! Đội bạn nghe tin liền nhường luôn bái phục =))";
                setTimeout(() => {
                    document.getElementById('quest-basketball').classList.add('hidden');
                    feedback.innerText = "";
                    pickRandomQuest();
                }, 2000);
            } else {
                feedback.style.color = "#ff3333";
                feedback.innerText = "Dùng chất kích thích là vi phạm luật rồi dính gậy ngay! Chọn lại đi!";
            }
        }


        // Hệ thống Gợi ý 3 lần cho câu đố YEUNHAU Đỉnh của chóp
        let hintStage = 0;
        function giveMathHint() {
            hintStage++;
            const fb = document.getElementById('math-feedback');
            fb.style.color = "#00b0ff";

            if (hintStage === 1) {
                fb.innerText = "Gợi ý lần 1: \"Chung minh\"";
                document.getElementById('hint-count').innerText = "2";
            } else if (hintStage === 2) {
                fb.innerText = "Gợi ý lần 2: \"Chung minh YEUNHAU\"";
                document.getElementById('hint-count').innerText = "1";
            } else if (hintStage === 3) {
                fb.innerText = "Gợi ý lần 3: \"Chung minh YEUNHAU la dinh cua chop\"";
                document.getElementById('hint-count').innerText = "0";
                document.getElementById('btn-hint').disabled = true;
            }
        }

        // Kiểm tra kết quả đáp án toán học nhập vào viết không dấu chuẩn chỉnh
        function checkMathAnswer() {
            let userAns = document.getElementById('math-answer').value.trim();
            const fb = document.getElementById('math-feedback');

            // Chuyển đổi chuỗi viết về không dấu hoặc so khớp trực tiếp chuỗi viết không dấu của người chơi
            if (userAns.toLowerCase() === "chung minh yeunhau la dinh cua chop") {
                fb.style.color = "#4caf50";
                fb.innerText = "Quá xuất sắc! Bạn đúng là đỉnh của chóp luôn.";
                setTimeout(() => {
                    nextScreen('quest-math', 'quest-smart');
                }, 2000);
            } else {
                fb.style.color = "#ff3333";
                fb.innerText = "Sai bét nhè rồi! Hãy chú ý viết đúng mẫu chữ không dấu nha, hoặc dùng thêm nút xem Gợi ý kìa!";
            }
        }

        // Xử lý Đáp án câu hỏi: Người thông minh nói nhiều
        function answerSmart(isTrue) {
            const fb = document.getElementById('smart-feedback');
            if (!isTrue) {
                fb.innerText = "🐱 Mèo nói: Ôi bạn thật thông minh";
            } else {
                fb.innerText = "🐱 Mèo nói: Sao bạn nói ngắn thế?";
            }
            document.getElementById('btn-go-end').classList.remove('hidden');
        }

        // Xử lý Cảm nhận màn hình kết thúc hiện icon 🥰
        function answerFeel() {
            document.getElementById('troll-zone').classList.remove('hidden');
        }
    </script>
</body>
</html>

